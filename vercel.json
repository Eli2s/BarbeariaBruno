{
    "version": 2,
    "crons": [
        {
            "path": "/api/cron/check-overdue",
            "schedule": "0 6 * * *"
        }
    ],
    "builds": [
        {
            "src": "API/src/server.ts",
            "use": "@vercel/node"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "API/src/server.ts"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}